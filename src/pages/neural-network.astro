---
import Base from '@/layouts/Base.astro';
import type { Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/utils';
import LiquidText from '@/components/ui/LiquidText.astro';

const locale: Locale = 'en';
const t = useTranslations(locale);

const datasets = [
  ['circle', 'Circle'],
  ['xor', 'XOR'],
  ['spiral', 'Spiral'],
  ['gaussian', 'Gaussian'],
] as const;
const activations = ['tanh', 'sigmoid', 'relu'] as const;
const learningRates = ['0.03', '0.15', '0.5'] as const;
---

<Base {locale} title={`${t('nn.title')} – Ondřej Úlehla`} description={t('nn.intro')}>
  <section class="mx-auto max-w-6xl px-5 py-14 sm:px-8 sm:py-20">
    <div class="mb-10">
      <h1 class="font-poster text-[length:clamp(3rem,6vw,4.5rem)]">
        <LiquidText text={t('nn.title')} />
      </h1>
      <p class="text-ink-muted mt-6 max-w-3xl leading-relaxed">{t('nn.intro')}</p>
    </div>

    <!-- control console: mirrors the visualization panels – a header strip with
         live telemetry + transport, a row of labelled parameter cells, then the
         editable architecture -->
    <div class="border-line mb-6 border">
      <!-- header strip: title · live telemetry · transport -->
      <div class="border-line flex min-h-11 flex-wrap items-center justify-between gap-x-6 gap-y-2 border-b px-3 py-1.5">
        <span class="text-ink font-mono text-xs font-semibold tracking-[0.15em] uppercase">
          {t('nn.panel.config')}
        </span>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
          <dl class="flex items-center gap-x-5 font-mono text-xs tabular-nums">
            <div class="flex items-baseline gap-1.5">
              <dt class="text-ink-faint tracking-[0.12em] uppercase">{t('nn.epoch')}</dt>
              <dd id="nn-epoch" class="text-ink inline-block w-8 text-right font-semibold">0</dd>
            </div>
            <div class="flex items-baseline gap-1.5">
              <dt class="text-ink-faint tracking-[0.12em] uppercase">{t('nn.loss')}</dt>
              <dd id="nn-loss" class="text-ink inline-block w-12 text-right font-semibold">–</dd>
            </div>
            <!-- the last ~240 loss samples, drawn by the lab -->
            <canvas id="nn-spark" class="hidden h-6 w-28 sm:block" aria-hidden="true"></canvas>
            <div class="flex items-baseline gap-1.5">
              <dt class="text-ink-faint tracking-[0.12em] uppercase">{t('nn.acc')}</dt>
              <dd id="nn-acc" class="text-ink inline-block w-10 text-right font-semibold">–</dd>
            </div>
          </dl>
          <div class="border-line flex items-stretch border">
            <button
              type="button"
              id="nn-toggle"
              data-pause={t('nn.pause')}
              data-resume={t('nn.resume')}
              class="nn-transport nn-transport-primary w-24">{t('nn.pause')}</button
            >
            <button
              type="button"
              id="nn-ffwd"
              aria-pressed="false"
              title={t('nn.turboTip')}
              class="nn-transport border-line border-l tabular-nums">{t('nn.turbo')}</button
            >
            <button type="button" id="nn-reset" class="nn-transport border-line border-l">{t('nn.reset')}</button>
          </div>
        </div>
      </div>

      <!-- parameter cells: hairline-divided columns of segmented controls -->
      <div class="grid divide-y divide-[var(--line)] sm:grid-cols-[4fr_3fr_3fr] sm:divide-x sm:divide-y-0">
        <div class="px-4 py-3.5">
          <p class="nn-cell-label">{t('nn.dataset')}</p>
          <div class="nn-seg mt-2.5" role="group">
            {
              datasets.map(([value, label], i) => (
                <button type="button" data-nn-dataset data-value={value} aria-pressed={i === 0 ? 'true' : 'false'} class="nn-seg-btn">
                  {label}
                </button>
              ))
            }
          </div>
        </div>
        <div class="px-4 py-3.5">
          <p class="nn-cell-label">{t('nn.activation')}</p>
          <div class="nn-seg mt-2.5" role="group">
            {
              activations.map((value, i) => (
                <button type="button" data-nn-activation data-value={value} aria-pressed={i === 0 ? 'true' : 'false'} class="nn-seg-btn">
                  {value}
                </button>
              ))
            }
          </div>
        </div>
        <div class="px-4 py-3.5">
          <p class="nn-cell-label">{t('nn.lr')}</p>
          <div class="nn-seg mt-2.5" role="group">
            {
              learningRates.map((value, i) => (
                <button type="button" data-nn-lr data-value={value} aria-pressed={i === 1 ? 'true' : 'false'} class="nn-seg-btn tabular-nums">
                  {value}
                </button>
              ))
            }
          </div>
        </div>
      </div>

      <!-- architecture: input features → hidden layers → output units -->
      <div class="border-line border-t px-4 py-3.5">
        <p class="nn-cell-label">{t('nn.layers')}</p>
        <div
          id="nn-layers"
          class="mt-3 flex flex-wrap items-end gap-1.5"
          data-l-input={t('nn.input')}
          data-l-output={t('nn.output')}
          data-l-add={t('nn.addLayer')}
          data-l-remove={t('nn.removeLayer')}
        >
        </div>
      </div>

      <!-- challenges: one-click configurations that show what the lab can do -->
      <div class="border-line border-t px-4 py-3.5">
        <p class="nn-cell-label">{t('nn.challenges')}</p>
        <div class="mt-2.5 flex flex-wrap gap-2">
          <button type="button" data-nn-preset="spiral" class="nn-add" title={t('nn.ch.spiralTip')}>
            {t('nn.ch.spiral')}
          </button>
          <button type="button" data-nn-preset="xor" class="nn-add" title={t('nn.ch.xorTip')}>
            {t('nn.ch.xor')}
          </button>
          <button type="button" data-nn-preset="classes" class="nn-add" title={t('nn.ch.classesTip')}>
            {t('nn.ch.classes')}
          </button>
        </div>
      </div>
    </div>

    <!-- panels: identical technical cells – header strip, plot, caption footer -->
    <div class="grid gap-6 lg:grid-cols-2">
      <figure class="border-line flex flex-col border">
        <div class="border-line flex min-h-11 items-center justify-between gap-3 border-b px-3 py-1.5">
          <span class="text-ink font-mono text-xs font-semibold tracking-[0.15em] uppercase">{t('nn.panel.surface')}</span>
          <div id="nn-legend" class="flex gap-4" data-l-class={t('nn.class')}></div>
        </div>
        <div class="p-3">
          <canvas id="nn-surface" class="mx-auto block aspect-square w-full max-w-[520px]"></canvas>
        </div>
        <figcaption class="border-line text-ink-faint mt-auto border-t px-3 py-2 font-mono text-xs leading-relaxed">
          {t('nn.surface')}
        </figcaption>
      </figure>
      <figure id="nn-schem-wrap" class="border-line relative flex flex-col border">
        <div class="border-line flex min-h-11 items-center justify-between gap-3 border-b px-3 py-1.5">
          <span class="text-ink font-mono text-xs font-semibold tracking-[0.15em] uppercase">{t('nn.panel.network')}</span>
          <div class="flex items-center gap-2">
            <span class="text-ink-faint font-mono text-xs tracking-wide uppercase">{t('nn.edges')}</span>
            <div class="nn-seg nn-seg-sm" role="group">
              <button
                type="button"
                data-nn-edges
                data-value="weights"
                aria-pressed="true"
                class="nn-seg-btn"
                title={t('nn.edges.weightsTip')}>{t('nn.edges.weights')}</button
              >
              <button
                type="button"
                data-nn-edges
                data-value="flow"
                aria-pressed="false"
                class="nn-seg-btn"
                title={t('nn.edges.flowTip')}>{t('nn.edges.flow')}</button
              >
            </div>
          </div>
        </div>
        <div class="p-3">
          <div id="nn-schematic" class="aspect-[56/43] w-full"></div>
        </div>
        <div id="nn-tip" class="nn-tip" hidden></div>
        <input id="nn-weight-edit" class="nn-weight-edit" type="number" step="0.01" hidden />
        <figcaption class="border-line text-ink-faint mt-auto border-t px-3 py-2 font-mono text-xs leading-relaxed">
          {t('nn.schematic')}
        </figcaption>
      </figure>
      <figure class="border-line flex flex-col border lg:col-span-2">
        <div class="border-line flex min-h-11 items-center border-b px-3 py-1.5">
          <span class="text-ink font-mono text-xs font-semibold tracking-[0.15em] uppercase">{t('nn.panel.model')}</span>
        </div>
        <div class="p-3">
          <canvas id="nn-3d" class="block aspect-square w-full sm:aspect-[2/1]"></canvas>
        </div>
        <figcaption class="border-line text-ink-faint border-t px-3 py-2 font-mono text-xs leading-relaxed">
          {t('nn.model')}
        </figcaption>
      </figure>
    </div>
    <p id="nn-webgl" class="text-ink-faint mt-4 text-sm" hidden>{t('nn.webgl')}</p>

    <!-- links: thesis, case study, source -->
    <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2">
      <a href="/thesis.pdf" download="ulehla-modelovani-neuronovych-siti-ve-vr.pdf" class="nn-link"
        >↓ {t('nn.links.thesis')}</a
      >
      <a href="/projects/neural-vr" class="nn-link">{t('nn.links.case')} →</a>
      <a href="https://github.com/ondraulehla/neural-network-visualizer" target="_blank" rel="noopener" class="nn-link"
        >{t('nn.links.code')} ↗</a
      >
    </div>

    <!-- about -->
    <div class="border-line mt-14 border-t pt-8">
      <h2 class="font-display text-ink text-xl font-bold tracking-[-0.01em] sm:text-2xl">{t('nn.about.title')}</h2>
      <div class="text-ink-muted mt-4 max-w-3xl space-y-4 leading-relaxed">
        <p>{t('nn.about.p1')}</p>
        <p>{t('nn.about.p2')}</p>
        <p>{t('nn.about.p3')}</p>
      </div>
    </div>
  </section>
</Base>

<style is:global>
  /* ---- control console ---------------------------------------------------- */
  .nn-cell-label {
    color: var(--ink-faint);
    font: 600 0.68rem/1 var(--font-mono);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  /* segmented control: joined buttons sharing hairline borders */
  .nn-seg {
    display: flex;
    border: 1px solid var(--line);
  }
  .nn-seg-btn {
    flex: 1 1 0;
    min-width: 0;
    padding: 0.5rem 0.4rem;
    font: 600 0.8rem/1 var(--font-sans);
    color: var(--ink-muted);
    border-right: 1px solid var(--line);
    cursor: pointer;
    white-space: nowrap;
    transition:
      background 0.15s,
      color 0.15s;
  }
  .nn-seg-btn:last-child {
    border-right: none;
  }
  .nn-seg-btn:hover:not([aria-pressed='true']) {
    color: var(--ink);
    background: color-mix(in oklab, var(--ink) 6%, transparent);
  }
  .nn-seg-btn[aria-pressed='true'] {
    background: var(--accent);
    color: var(--surface);
  }
  .nn-seg-sm .nn-seg-btn {
    flex: 0 0 auto;
    padding: 0.3rem 0.6rem;
    font-size: 0.72rem;
  }

  /* transport buttons (Pause / Reset) */
  .nn-transport {
    padding: 0.45rem 0.9rem;
    font: 600 0.72rem/1 var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    cursor: pointer;
    transition:
      background 0.15s,
      color 0.15s;
  }
  .nn-transport:hover {
    background: color-mix(in oklab, var(--ink) 8%, transparent);
  }
  .nn-transport-primary {
    background: var(--accent);
    color: var(--surface);
  }
  .nn-transport-primary:hover {
    background: var(--accent-strong);
    color: var(--surface);
  }
  /* latched transport state (the ×5 fast-forward) */
  .nn-transport[aria-pressed='true'] {
    background: var(--accent);
    color: var(--surface);
  }
  .nn-transport[aria-pressed='true']:hover {
    background: var(--accent-strong);
  }

  /* architecture steppers: a labelled group per layer */
  .nn-named {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .nn-layer {
    display: inline-flex;
    align-items: stretch;
    height: 2rem;
    border: 1px solid var(--line);
  }
  .nn-step {
    width: 1.8rem;
    color: var(--ink-muted);
    font: 700 1rem/1 var(--font-mono);
    cursor: pointer;
    transition:
      background 0.15s,
      color 0.15s;
  }
  .nn-step:first-child {
    border-right: 1px solid var(--line);
  }
  .nn-count + .nn-step {
    border-left: 1px solid var(--line);
  }
  .nn-step:hover:not(:disabled) {
    color: var(--ink);
    background: color-mix(in oklab, var(--ink) 8%, transparent);
  }
  .nn-step:disabled {
    opacity: 0.3;
    cursor: default;
  }
  .nn-count {
    display: flex;
    min-width: 2rem;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    font: 700 0.85rem/1 var(--font-mono);
    font-variant-numeric: tabular-nums;
  }
  .nn-remove {
    display: flex;
    width: 1.5rem;
    align-items: center;
    justify-content: center;
    border-left: 1px solid var(--line);
    color: var(--ink-faint);
    font: 700 0.9rem/1 var(--font-mono);
    cursor: pointer;
    transition:
      background 0.15s,
      color 0.15s;
  }
  .nn-remove:hover {
    color: var(--surface);
    background: var(--accent);
  }
  .nn-arrow {
    align-self: center;
    margin-top: 0.9rem;
    color: var(--ink-faint);
    font: 400 0.8rem/1 var(--font-mono);
  }
  .nn-add {
    height: 2rem;
    padding: 0 0.9rem;
    border: 1px dashed var(--line);
    color: var(--ink-muted);
    font: 600 0.72rem/1 var(--font-mono);
    letter-spacing: 0.05em;
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s,
      color 0.15s;
  }
  .nn-add:hover:not(:disabled) {
    border-color: var(--accent);
    color: var(--accent);
  }
  .nn-add:disabled {
    opacity: 0.3;
    cursor: default;
  }
  .nn-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--ink-muted);
    font: 600 0.75rem/1 var(--font-mono);
  }
  .nn-legend-dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
  }
  .nn-tag {
    color: var(--ink-faint);
    font: 600 0.65rem/1 var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .nn-link {
    color: var(--accent);
    font: 600 0.85rem/1.4 var(--font-sans);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .nn-link:hover {
    border-color: var(--accent);
  }
  .nn-tip {
    position: absolute;
    z-index: 30;
    pointer-events: none;
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 0.2rem 0.45rem;
    color: var(--ink);
    font: 600 0.75rem/1.4 var(--font-mono);
    box-shadow: 0 2px 10px rgb(0 0 0 / 0.12);
    transform: translate(-50%, -130%);
    white-space: nowrap;
  }
  .nn-weight-edit {
    position: absolute;
    z-index: 40;
    width: 5.2rem;
    transform: translate(-50%, -50%);
    background: var(--surface);
    border: 1.5px solid var(--accent);
    padding: 0.25rem 0.4rem;
    color: var(--ink);
    font: 600 0.8rem/1.2 var(--font-mono);
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.18);
  }
  .nn-weight-edit:focus {
    outline: none;
  }
  #nn-schematic svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .nn-edge-hit,
  .nn-neuron-hit {
    cursor: pointer;
  }
</style>

<script>
  function webglOk() {
    try {
      const c = document.createElement('canvas');
      return !!(c.getContext('webgl2') || c.getContext('webgl'));
    } catch {
      return false;
    }
  }
  // astro:page-load fires on the initial load AND after every client-side
  // navigation, so the lab re-initializes when the user comes back to it
  function initLab() {
    if (!document.getElementById('nn-surface')) return;
    if (webglOk()) {
      import('@/neural/experience')
        .then((m) => m.initNeural())
        .catch(() => {
          // stale chunk from a previous deploy – one hard reload recovers
          try {
            if (sessionStorage.getItem('chunk-reload')) return;
            sessionStorage.setItem('chunk-reload', '1');
          } catch {}
          location.reload();
        });
    } else {
      const note = document.getElementById('nn-webgl');
      if (note) note.hidden = false;
    }
  }
  document.addEventListener('astro:page-load', initLab);
</script>
