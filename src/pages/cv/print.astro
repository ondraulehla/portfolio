---
import '@/styles/global.css';
import type { Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/utils';
import { cv, formatMonth, skillLabel } from '@/data/cv';
import { site } from '@/data/site';

const locale: Locale = 'en';
const t = useTranslations(locale);
---

<!doctype html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{cv.profile.name} – {t('cv.print.title')}</title>
    <style>
      @page {
        size: A4;
        margin: 11mm 14mm;
      }
      html {
        font-size: 11.5px;
      }
      section {
        break-inside: avoid;
      }
      /* the site's hatch tape, print-safe */
      .cv-hatch {
        height: 6px;
        width: 118px;
        background-image: repeating-linear-gradient(
          -45deg,
          transparent 0 4px,
          rgba(41, 34, 27, 0.45) 4px 5px
        );
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
      }
      .cv-accent {
        color: #cb3a00;
      }
      .cv-rule {
        border-color: rgba(41, 34, 27, 0.55);
      }
      .cv-hairline {
        border-color: #ddd5c4;
      }
    </style>
  </head>
  <body class="bg-white font-sans text-[#29221b]">
    <!-- masthead in the site language: poster name, mono spec line, rule + hatch -->
    <header>
      <div class="flex items-end justify-between gap-6">
        <h1 class="font-poster cv-accent text-[34px] leading-none">{cv.profile.name}</h1>
        <p class="font-mono text-[10.5px] tracking-[0.14em] text-neutral-500 uppercase">
          {site.location[locale]}
        </p>
      </div>
      <p class="mt-1.5 text-lg font-semibold">{cv.profile.title[locale]}</p>
      <p class="mt-1.5 font-mono text-xs text-neutral-600">
        {site.email} · {site.github.replace('https://', '')} · ondrejulehla.dev
      </p>
      <div class="cv-rule mt-3 border-b-2"></div>
      <div class="cv-hatch mt-1.5"></div>
    </header>

    <section class="mt-4">
      {cv.profile.bio.map((p) => <p class="mt-2 leading-relaxed text-neutral-700">{p[locale]}</p>)}
    </section>

    <section class="mt-5">
      <h2 class="cv-hairline cv-accent border-b pb-1 font-mono text-xs font-bold tracking-[0.18em] uppercase">
        {t('experience.heading')}
      </h2>
      {
        cv.experience.map((job) => (
          <div class="mt-4">
            <div class="flex items-baseline justify-between">
              <h3 class="font-semibold">
                {job.role[locale]} · {job.company}
              </h3>
              <p class="font-mono text-xs text-neutral-500">
                {formatMonth(job.start, locale)} – {job.end ? formatMonth(job.end, locale) : t('experience.present')}
              </p>
            </div>
            <p class="mt-1 text-neutral-700">{job.summary[locale]}</p>
            <ul class="mt-1.5 list-disc space-y-1 pl-5 text-neutral-700">
              {job.highlights.map((h) => (
                <li>{h[locale]}</li>
              ))}
            </ul>
            <p class="mt-1.5 font-mono text-xs text-neutral-500">{job.tech.join(' · ')}</p>
          </div>
        ))
      }
    </section>

    <section class="mt-5">
      <h2 class="cv-hairline cv-accent border-b pb-1 font-mono text-xs font-bold tracking-[0.18em] uppercase">
        {t('education.heading')}
      </h2>
      {
        cv.education.map((item) => (
          <div class="mt-3 flex items-baseline justify-between">
            <div>
              <h3 class="font-semibold">{item.school}</h3>
              <p class="text-neutral-700">{item.degree[locale]}</p>
            </div>
            <p class="font-mono text-xs text-neutral-500">
              {formatMonth(item.start, locale)} – {item.end ? formatMonth(item.end, locale) : t('experience.present')}
            </p>
          </div>
        ))
      }
    </section>

    <section class="mt-5">
      <h2 class="cv-hairline cv-accent border-b pb-1 font-mono text-xs font-bold tracking-[0.18em] uppercase">
        {t('skills.heading')}
      </h2>
      <dl class="mt-3 space-y-1.5">
        {
          cv.skills.map((group) => (
            <div class="flex gap-3">
              <dt class="w-36 shrink-0 font-semibold">{group.category[locale]}:</dt>
              <dd class="text-neutral-700">{group.items.map((i) => skillLabel(i, locale)).join(', ')}</dd>
            </div>
          ))
        }
        <div class="flex gap-3">
          <dt class="w-36 shrink-0 font-semibold">Spoken languages:</dt>
          <dd class="text-neutral-700">
            {cv.languages.map((l) => `${l.name[locale]} (${l.level[locale]})`).join(', ')}
          </dd>
        </div>
      </dl>
    </section>
  </body>
</html>
