---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '@/layouts/Base.astro';
import Badge from '@/components/ui/Badge.astro';
import { locales, type Locale } from '@/i18n/config';
import { localePath, useTranslations } from '@/i18n/utils';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => {
    const [lang, ...rest] = entry.id.split('/');
    return { params: { lang, slug: rest.join('/') }, props: { entry } };
  });
}

const { entry } = Astro.props;
const locale = Astro.params.lang as Locale;
const slug = Astro.params.slug!;
const t = useTranslations(locale);
const { Content } = await render(entry);

const siblings = (await getCollection('projects', (e) => e.id.startsWith(`${locale}/`))).sort(
  (a, b) => a.data.order - b.data.order,
);
const index = siblings.findIndex((e) => e.id === entry.id);
const next = siblings[(index + 1) % siblings.length];
const nextSlug = next && next.id !== entry.id ? next.id.split('/').slice(1).join('/') : null;

const meta = [
  { label: t('project.role'), value: entry.data.role },
  { label: t('project.year'), value: String(entry.data.year) },
];
---

<Base {locale} title={`${entry.data.title} – Ondřej Úlehla`} description={entry.data.summary}>
  <article class="mx-auto max-w-4xl px-5 py-14 sm:px-8 sm:py-20">
    <a
      href={`${localePath(locale, '/')}#projects`}
      class="text-ink-muted hover:text-ink inline-flex items-center gap-1.5 text-sm font-medium transition-colors"
    >
      <svg
        class="size-4"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"><path d="M19 12H5m7 7-7-7 7-7"></path></svg
      >
      {t('project.back')}
    </a>

    <header class="mt-8">
      <h1
        class="font-display text-ink text-[length:var(--text-fluid-lg)] leading-tight font-bold tracking-tight"
        transition:name={`title-${slug}`}
      >
        {entry.data.title}
      </h1>
      <p class="text-ink-muted mt-4 max-w-2xl text-lg leading-relaxed">{entry.data.summary}</p>

      <dl class="text-ink-muted mt-6 flex flex-wrap gap-x-10 gap-y-3 text-sm">
        {
          meta.map((item) => (
            <div>
              <dt class="text-ink-faint font-mono text-xs tracking-wide uppercase">{item.label}</dt>
              <dd class="text-ink mt-1 font-medium">{item.value}</dd>
            </div>
          ))
        }
        <div>
          <dt class="text-ink-faint font-mono text-xs tracking-wide uppercase">{t('project.stack')}</dt>
          <dd class="mt-1.5 flex max-w-md flex-wrap gap-1.5">
            {entry.data.tech.map((item) => <Badge>{item}</Badge>)}
          </dd>
        </div>
      </dl>

      {
        (entry.data.links.repo || entry.data.links.live) && (
          <div class="mt-6 flex gap-4 text-sm font-semibold">
            {entry.data.links.repo && (
              <a href={entry.data.links.repo} target="_blank" rel="noopener" class="text-accent hover:text-accent-strong underline underline-offset-4">
                {t('project.repo')} ↗
              </a>
            )}
            {entry.data.links.live && (
              <a href={entry.data.links.live} target="_blank" rel="noopener" class="text-accent hover:text-accent-strong underline underline-offset-4">
                {t('project.live')} ↗
              </a>
            )}
          </div>
        )
      }
    </header>

    <Image
      src={entry.data.cover}
      alt=""
      widths={[768, 1200, 1600]}
      sizes="(min-width: 1024px) 896px, 100vw"
      class="border-line mt-10 aspect-video w-full rounded-2xl border object-cover"
      transition:name={`cover-${slug}`}
      loading="eager"
      fetchpriority="high"
    />

    <div class="border-line mt-10 grid gap-4 sm:grid-cols-3" data-reveal>
      {
        (
          [
            [t('project.problem'), entry.data.problem],
            [t('project.solution'), entry.data.solution],
            [t('project.outcome'), entry.data.outcome],
          ] as const
        ).map(([label, text]) => (
          <div class="border-line bg-panel/50 rounded-2xl border p-5">
            <h2 class="text-accent font-mono text-xs font-semibold tracking-[0.15em] uppercase">{label}</h2>
            <p class="text-ink-muted mt-2 text-sm leading-relaxed">{text}</p>
          </div>
        ))
      }
    </div>

    <div class="prose-custom mt-12 max-w-none">
      <Content />
    </div>

    {
      nextSlug && (
        <footer class="border-line mt-16 border-t pt-8">
          <a
            href={localePath(locale, `/projects/${nextSlug}`)}
            data-astro-prefetch="hover"
            class="group flex items-center justify-between"
          >
            <div>
              <p class="text-ink-faint font-mono text-xs tracking-wide uppercase">{t('project.next')}</p>
              <p class="font-display text-ink group-hover:text-accent mt-1 text-xl font-semibold transition-colors">
                {next!.data.title}
              </p>
            </div>
            <svg
              class="text-ink-muted group-hover:text-accent size-6 transition-all group-hover:translate-x-1"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14m-7-7 7 7-7 7" />
            </svg>
          </a>
        </footer>
      )
    }
  </article>
</Base>
