---
import Base from '@/layouts/Base.astro';
import { locales, type Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/utils';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);

const datasets = [
  ['circle', 'Circle'],
  ['xor', 'XOR'],
  ['spiral', 'Spiral'],
  ['gaussian', 'Gaussian'],
] as const;
const activations = ['tanh', 'sigmoid', 'relu'] as const;
const learningRates = ['0.03', '0.15', '0.5'] as const;
---

<Base {locale} title={`${t('nn.title')} – Ondřej Úlehla`} description={t('nn.intro')}>
  <section class="mx-auto max-w-6xl px-5 py-14 sm:px-8 sm:py-20">
    <div class="border-line mb-10 border-t pt-5">
      <p class="text-accent font-mono text-xs font-semibold tracking-[0.2em] uppercase">{t('nn.kicker')}</p>
      <h1 class="font-display text-ink mt-3 text-3xl font-bold tracking-[-0.02em] sm:text-4xl">{t('nn.title')}</h1>
      <p class="text-ink-muted mt-4 max-w-3xl leading-relaxed">{t('nn.intro')}</p>
      <div class="mt-5 flex flex-wrap gap-x-6 gap-y-2">
        <a href="/thesis.pdf" download="ulehla-modelovani-neuronovych-siti-ve-vr.pdf" class="nn-link">↓ {t('nn.links.thesis')}</a>
        <a href={`/${locale}/projects/neural-vr`} class="nn-link">{t('nn.links.case')} →</a>
        <a href="https://github.com/ondraulehla/neural-network-visualizer" target="_blank" rel="noopener" class="nn-link"
          >{t('nn.links.code')} ↗</a
        >
      </div>
    </div>

    <!-- controls -->
    <div class="border-line mb-6 flex flex-wrap items-end gap-x-8 gap-y-4 rounded-xl border p-4">
      <div>
        <p class="text-ink-faint mb-1.5 font-mono text-xs tracking-wide uppercase">{t('nn.dataset')}</p>
        <div class="flex gap-1.5" role="group">
          {
            datasets.map(([value, label], i) => (
              <button
                type="button"
                data-nn-dataset
                data-value={value}
                aria-pressed={i === 0 ? 'true' : 'false'}
                class="nn-chip"
              >
                {label}
              </button>
            ))
          }
        </div>
      </div>

      <div>
        <p class="text-ink-faint mb-1.5 font-mono text-xs tracking-wide uppercase">{t('nn.activation')}</p>
        <div class="flex gap-1.5" role="group">
          {
            activations.map((value, i) => (
              <button type="button" data-nn-activation data-value={value} aria-pressed={i === 0 ? 'true' : 'false'} class="nn-chip">
                {value}
              </button>
            ))
          }
        </div>
      </div>

      <div>
        <p class="text-ink-faint mb-1.5 font-mono text-xs tracking-wide uppercase">{t('nn.lr')}</p>
        <div class="flex gap-1.5" role="group">
          {
            learningRates.map((value, i) => (
              <button type="button" data-nn-lr data-value={value} aria-pressed={i === 1 ? 'true' : 'false'} class="nn-chip">
                {value}
              </button>
            ))
          }
        </div>
      </div>

      <div class="ml-auto flex items-end gap-4">
        <div class="text-ink-faint font-mono text-xs">
          <div>{t('nn.epoch')} <span id="nn-epoch" class="text-ink">0</span></div>
          <div>{t('nn.loss')} <span id="nn-loss" class="text-ink">–</span></div>
          <div>{t('nn.acc')} <span id="nn-acc" class="text-ink">–</span></div>
        </div>
        <button type="button" id="nn-toggle" data-pause={t('nn.pause')} data-resume={t('nn.resume')} class="nn-chip nn-chip-solid"
          >{t('nn.pause')}</button
        >
        <button type="button" id="nn-reset" class="nn-chip">{t('nn.reset')}</button>
      </div>

      <div class="basis-full">
        <p class="text-ink-faint mb-1.5 font-mono text-xs tracking-wide uppercase">{t('nn.layers')}</p>
        <div
          id="nn-layers"
          class="flex flex-wrap items-end gap-2"
          data-l-input={t('nn.input')}
          data-l-output={t('nn.output')}
          data-l-add={t('nn.addLayer')}
          data-l-remove={t('nn.removeLayer')}
        >
        </div>
      </div>
    </div>

    <!-- panels -->
    <div class="grid gap-6 lg:grid-cols-2">
      <figure class="border-line rounded-xl border p-3">
        <canvas id="nn-surface" class="mx-auto block aspect-square w-full max-w-[520px] rounded-lg"></canvas>
        <div id="nn-legend" class="mt-3 flex justify-center gap-5" data-l-class={t('nn.class')}></div>
        <figcaption class="text-ink-faint mt-2 text-center font-mono text-xs">{t('nn.surface')}</figcaption>
      </figure>
      <figure id="nn-schem-wrap" class="border-line relative rounded-xl border p-3">
        <div class="mb-1 flex items-center justify-end gap-1.5">
          <span class="text-ink-faint mr-1 font-mono text-xs tracking-wide uppercase">{t('nn.edges')}</span>
          <button
            type="button"
            data-nn-edges
            data-value="weights"
            aria-pressed="true"
            class="nn-chip nn-chip-sm"
            title={t('nn.edges.weightsTip')}>{t('nn.edges.weights')}</button
          >
          <button
            type="button"
            data-nn-edges
            data-value="flow"
            aria-pressed="false"
            class="nn-chip nn-chip-sm"
            title={t('nn.edges.flowTip')}>{t('nn.edges.flow')}</button
          >
        </div>
        <div id="nn-schematic" class="aspect-[56/43] w-full"></div>
        <div id="nn-tip" class="nn-tip" hidden></div>
        <input id="nn-weight-edit" class="nn-weight-edit" type="number" step="0.01" hidden />
        <figcaption class="text-ink-faint mt-2 text-center font-mono text-xs">{t('nn.schematic')}</figcaption>
      </figure>
      <figure class="border-line rounded-xl border p-3 lg:col-span-2">
        <canvas id="nn-3d" class="block aspect-square w-full rounded-lg sm:aspect-[2/1]"></canvas>
        <figcaption class="text-ink-faint mt-2 text-center font-mono text-xs">{t('nn.model')}</figcaption>
      </figure>
    </div>
    <p id="nn-webgl" class="text-ink-faint mt-4 text-sm" hidden>{t('nn.webgl')}</p>

    <!-- about -->
    <div class="border-line mt-14 border-t pt-8">
      <h2 class="font-display text-ink text-xl font-bold tracking-[-0.01em] sm:text-2xl">{t('nn.about.title')}</h2>
      <div class="text-ink-muted mt-4 max-w-3xl space-y-4 leading-relaxed">
        <p>{t('nn.about.p1')}</p>
        <p>{t('nn.about.p2')}</p>
        <p>{t('nn.about.p3')}</p>
      </div>
    </div>
  </section>
</Base>

<style is:global>
  .nn-chip {
    border: 1px solid var(--line);
    color: var(--ink-muted);
    border-radius: 0.5rem;
    padding: 0.4rem 0.8rem;
    font: 600 0.8rem/1 var(--font-sans);
    cursor: pointer;
    transition: all 0.15s;
  }
  .nn-chip:hover {
    color: var(--ink);
    border-color: var(--ink-faint);
  }
  .nn-chip[aria-pressed='true'] {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--surface);
  }
  .nn-chip-solid {
    background: var(--ink);
    color: var(--surface);
    border-color: var(--ink);
  }
  .nn-chip:disabled {
    opacity: 0.35;
    cursor: default;
  }
  .nn-chip-sm {
    padding: 0.3rem 0.6rem;
    font-size: 0.72rem;
  }
  .nn-layer {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid var(--line);
    border-radius: 0.5rem;
    padding: 0.25rem 0.4rem;
  }
  .nn-layer-fixed {
    color: var(--ink-faint);
    font: 600 0.75rem/1 var(--font-mono);
    padding: 0.55rem 0.6rem;
  }
  .nn-step {
    width: 1.6rem;
    height: 1.6rem;
    border: 1px solid var(--line);
    border-radius: 0.4rem;
    color: var(--ink-muted);
    font: 700 0.85rem/1 var(--font-mono);
    cursor: pointer;
  }
  .nn-step:hover:not(:disabled) {
    color: var(--ink);
    border-color: var(--ink-faint);
  }
  .nn-step:disabled {
    opacity: 0.35;
    cursor: default;
  }
  .nn-count {
    min-width: 1.4rem;
    text-align: center;
    color: var(--ink);
    font: 700 0.85rem/1 var(--font-mono);
  }
  .nn-remove {
    color: var(--ink-faint);
    font: 700 0.8rem/1 var(--font-mono);
    padding: 0 0.2rem;
    cursor: pointer;
  }
  .nn-remove:hover {
    color: var(--accent);
  }
  .nn-arrow {
    color: var(--ink-faint);
    font: 600 0.8rem/1 var(--font-mono);
    margin-bottom: 0.75rem;
  }
  .nn-named {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  .nn-named > .nn-chip {
    padding-block: 0.55rem;
  }
  .nn-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--ink-muted);
    font: 600 0.75rem/1 var(--font-mono);
  }
  .nn-legend-dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
  }
  .nn-tag {
    color: var(--ink-faint);
    font: 600 0.65rem/1 var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .nn-link {
    color: var(--accent);
    font: 600 0.85rem/1.4 var(--font-sans);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .nn-link:hover {
    border-color: var(--accent);
  }
  .nn-tip {
    position: absolute;
    z-index: 30;
    pointer-events: none;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 0.4rem;
    padding: 0.2rem 0.45rem;
    color: var(--ink);
    font: 600 0.75rem/1.4 var(--font-mono);
    box-shadow: 0 2px 10px rgb(0 0 0 / 0.12);
    transform: translate(-50%, -130%);
    white-space: nowrap;
  }
  .nn-weight-edit {
    position: absolute;
    z-index: 40;
    width: 5.2rem;
    transform: translate(-50%, -50%);
    background: var(--surface);
    border: 1.5px solid var(--accent);
    border-radius: 0.4rem;
    padding: 0.25rem 0.4rem;
    color: var(--ink);
    font: 600 0.8rem/1.2 var(--font-mono);
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.18);
  }
  .nn-weight-edit:focus {
    outline: none;
  }
  #nn-schematic svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .nn-edge-hit,
  .nn-neuron-hit {
    cursor: pointer;
  }
</style>

<script>
  function webglOk() {
    try {
      const c = document.createElement('canvas');
      return !!(c.getContext('webgl2') || c.getContext('webgl'));
    } catch {
      return false;
    }
  }
  // astro:page-load fires on the initial load AND after every client-side
  // navigation, so the lab re-initializes when the user comes back to it
  function initLab() {
    if (!document.getElementById('nn-surface')) return;
    if (webglOk()) {
      import('@/neural/experience').then((m) => m.initNeural());
    } else {
      const note = document.getElementById('nn-webgl');
      if (note) note.hidden = false;
    }
  }
  document.addEventListener('astro:page-load', initLab);
</script>
