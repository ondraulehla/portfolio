---
import '@/styles/global.css';
import { locales, type Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/utils';
import { cv, formatMonth, skillLabel } from '@/data/cv';
import { site } from '@/data/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);
---

<!doctype html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{cv.profile.name} — {t('cv.print.title')}</title>
    <style>
      @page {
        size: A4;
        margin: 14mm 16mm;
      }
      html {
        font-size: 13px;
      }
    </style>
  </head>
  <body class="bg-white font-sans text-neutral-900">
    <header class="border-b border-neutral-300 pb-4">
      <h1 class="font-display text-3xl font-bold tracking-tight">{cv.profile.name}</h1>
      <p class="mt-1 text-lg text-neutral-600">{cv.profile.title[locale]}</p>
      <p class="mt-2 font-mono text-xs text-neutral-500">
        {site.email} · {site.github.replace('https://', '')} · {site.location[locale]}
      </p>
    </header>

    <section class="mt-5">
      {cv.profile.bio.map((p) => <p class="mt-2 leading-relaxed text-neutral-700">{p[locale]}</p>)}
    </section>

    <section class="mt-6">
      <h2 class="font-display border-b border-neutral-200 pb-1 text-sm font-bold tracking-[0.15em] uppercase">
        {t('experience.heading')}
      </h2>
      {
        cv.experience.map((job) => (
          <div class="mt-4">
            <div class="flex items-baseline justify-between">
              <h3 class="font-semibold">
                {job.role[locale]} · {job.company}
              </h3>
              <p class="font-mono text-xs text-neutral-500">
                {formatMonth(job.start, locale)} — {job.end ? formatMonth(job.end, locale) : t('experience.present')}
              </p>
            </div>
            <p class="mt-1 text-neutral-700">{job.summary[locale]}</p>
            <ul class="mt-1.5 list-disc space-y-1 pl-5 text-neutral-700">
              {job.highlights.map((h) => (
                <li>{h[locale]}</li>
              ))}
            </ul>
            <p class="mt-1.5 font-mono text-xs text-neutral-500">{job.tech.join(' · ')}</p>
          </div>
        ))
      }
    </section>

    <section class="mt-6">
      <h2 class="font-display border-b border-neutral-200 pb-1 text-sm font-bold tracking-[0.15em] uppercase">
        {t('education.heading')}
      </h2>
      {
        cv.education.map((item) => (
          <div class="mt-3 flex items-baseline justify-between">
            <div>
              <h3 class="font-semibold">{item.school}</h3>
              <p class="text-neutral-700">{item.degree[locale]}</p>
            </div>
            <p class="font-mono text-xs text-neutral-500">
              {formatMonth(item.start, locale)} — {item.end ? formatMonth(item.end, locale) : t('experience.present')}
            </p>
          </div>
        ))
      }
    </section>

    <section class="mt-6">
      <h2 class="font-display border-b border-neutral-200 pb-1 text-sm font-bold tracking-[0.15em] uppercase">
        {t('skills.heading')}
      </h2>
      <dl class="mt-3 space-y-1.5">
        {
          cv.skills.map((group) => (
            <div class="flex gap-3">
              <dt class="w-36 shrink-0 font-semibold">{group.category[locale]}:</dt>
              <dd class="text-neutral-700">{group.items.map((i) => skillLabel(i, locale)).join(', ')}</dd>
            </div>
          ))
        }
        <div class="flex gap-3">
          <dt class="w-36 shrink-0 font-semibold">{locale === 'cs' ? 'Jazyky' : 'Languages'}:</dt>
          <dd class="text-neutral-700">
            {cv.languages.map((l) => `${l.name[locale]} (${l.level[locale]})`).join(', ')}
          </dd>
        </div>
      </dl>
    </section>
  </body>
</html>
