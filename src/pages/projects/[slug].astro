---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '@/layouts/Base.astro';
import Badge from '@/components/ui/Badge.astro';
import LiquidText from '@/components/ui/LiquidText.astro';
import type { Locale } from '@/i18n/config';
import { localePath, useTranslations } from '@/i18n/utils';

export async function getStaticPaths() {
  const entries = await getCollection('projects', (e) => e.id.startsWith('en/'));
  return entries.map((entry) => ({
    params: { slug: entry.id.split('/').slice(1).join('/') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const locale: Locale = 'en';
const slug = Astro.params.slug!;
const t = useTranslations(locale);
const { Content } = await render(entry);

const siblings = (await getCollection('projects', (e) => e.id.startsWith(`${locale}/`))).sort(
  (a, b) => a.data.order - b.data.order,
);
const index = siblings.findIndex((e) => e.id === entry.id);
const next = siblings[(index + 1) % siblings.length];
const nextSlug = next && next.id !== entry.id ? next.id.split('/').slice(1).join('/') : null;
---

<Base {locale} title={`${entry.data.title} – Ondřej Úlehla`} description={entry.data.summary} ogImage={`/og/${slug}.png`}>
  <article class="mx-auto max-w-4xl px-5 py-14 sm:px-8 sm:py-20">
    <a
      href={`${localePath(locale, '/')}#projects`}
      class="text-ink-muted hover:text-accent inline-flex items-center gap-2 font-mono text-xs tracking-[0.15em] uppercase transition-colors"
    >
      ← {t('project.back')}
    </a>

    <header class="mt-8">
      <h1 class="font-poster text-[length:clamp(2.6rem,5.5vw,4rem)]" transition:name={`title-${slug}`}>
        <LiquidText text={entry.data.title} />
      </h1>
      <p class="text-ink-muted mt-5 max-w-2xl text-lg leading-relaxed">{entry.data.summary}</p>
    </header>

    <!-- spec band: hairline cells like the header, links flood with ink -->
    <div class="border-line mt-8 border" data-reveal>
      <dl class="flex flex-wrap items-stretch font-mono text-xs">
        <div class="border-line border-r px-5 py-3">
          <dt class="text-ink-faint tracking-[0.15em] uppercase">{t('project.role')}</dt>
          <dd class="text-ink mt-1 font-semibold">{entry.data.role}</dd>
        </div>
        <div class="border-line border-r px-5 py-3">
          <dt class="text-ink-faint tracking-[0.15em] uppercase">{t('project.year')}</dt>
          <dd class="text-accent mt-1 font-semibold">{entry.data.year}</dd>
        </div>
        <div class="min-w-4 flex-1"></div>
        {
          entry.data.links.repo && (
            <a
              href={entry.data.links.repo}
              target="_blank"
              rel="noopener"
              class="cell-flood border-line flex items-center border-l px-5 font-semibold tracking-[0.15em] uppercase"
            >
              {t('project.repo')} ↗
            </a>
          )
        }
        {
          entry.data.links.live && (
            <a
              href={entry.data.links.live}
              target="_blank"
              rel="noopener"
              class="cell-flood border-line flex items-center border-l px-5 font-semibold tracking-[0.15em] uppercase"
            >
              {t('project.live')} ↗
            </a>
          )
        }
      </dl>
      <div class="border-line flex flex-wrap items-baseline gap-x-3 gap-y-1.5 border-t px-5 py-3">
        <span class="text-ink-faint font-mono text-xs tracking-[0.15em] uppercase">{t('project.stack')}</span>
        <span class="flex flex-wrap gap-1.5">
          {entry.data.tech.map((item) => <Badge>{item}</Badge>)}
        </span>
      </div>
    </div>

    <Image
      src={entry.data.cover}
      alt=""
      widths={[768, 1200, 1600]}
      sizes="(min-width: 1024px) 896px, 100vw"
      class="border-line mt-10 aspect-video w-full border object-cover"
      transition:name={`cover-${slug}`}
      loading="eager"
      fetchpriority="high"
    />

    <!-- problem / solution / outcome as one panel of technical cells -->
    <div
      class="border-line mt-10 grid divide-y divide-[var(--line)] border sm:grid-cols-3 sm:divide-x sm:divide-y-0"
      data-reveal
    >
      {
        (
          [
            [t('project.problem'), entry.data.problem],
            [t('project.solution'), entry.data.solution],
            [t('project.outcome'), entry.data.outcome],
          ] as const
        ).map(([label, text]) => (
          <div class="flex flex-col">
            <h2 class="border-line text-accent border-b px-5 py-2.5 font-mono text-xs font-semibold tracking-[0.15em] uppercase">
              {label}
            </h2>
            <p class="text-ink-muted p-5 text-sm leading-relaxed">{text}</p>
          </div>
        ))
      }
    </div>

    <div class="prose-custom mt-12 max-w-none">
      <Content />
    </div>

    {
      nextSlug && (
        <footer class="mt-16">
          <a
            href={localePath(locale, `/projects/${nextSlug}`)}
            data-astro-prefetch="hover"
            class="cell-flood border-line group flex items-center justify-between border px-5 py-4"
          >
            <div>
              <p class="font-mono text-xs tracking-[0.15em] uppercase opacity-60">{t('project.next')}</p>
              <p class="font-poster mt-1 text-2xl">{next!.data.title}</p>
            </div>
            <span class="font-mono text-xl" aria-hidden="true">
              →
            </span>
          </a>
        </footer>
      )
    }
  </article>
</Base>
