---
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';
import Seo from '@/components/seo/Seo.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SkipLink from '@/components/SkipLink.astro';
import type { Locale } from '@/i18n/config';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  /** Bare pages (playground, print) skip header/footer chrome. */
  chrome?: boolean;
}

const { locale, title, description, ogImage, noindex, chrome = true } = Astro.props;
---

<!doctype html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      // Pre-paint theme resolution — must stay inline and tiny to avoid FOUC.
      (function () {
        function apply() {
          var stored = null;
          try {
            stored = localStorage.getItem('theme');
          } catch {}
          var theme =
            stored ||
            (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        }
        apply();
        // Re-apply after View Transitions swap in a fresh <html>.
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
    <Seo {title} {description} {locale} {ogImage} {noindex} />
    <JsonLd {locale} />
    <ClientRouter />
  </head>
  <body class="flex min-h-svh flex-col">
    <SkipLink {locale} />
    {chrome && <Header {locale} />}
    <main id="main" class="flex-1">
      <slot />
    </main>
    {chrome && <Footer {locale} />}
    <script src="@/scripts/animations.ts"></script>
  </body>
</html>
