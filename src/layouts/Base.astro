---
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';
import Seo from '@/components/seo/Seo.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SkipLink from '@/components/SkipLink.astro';
import type { Locale } from '@/i18n/config';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  /** Bare pages (playground, print) skip header/footer chrome. */
  chrome?: boolean;
}

const { locale, title, description, ogImage, noindex, chrome = true } = Astro.props;
---

<!doctype html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      // Pre-paint theme resolution – must stay inline and tiny to avoid FOUC.
      (function () {
        function apply() {
          var stored = null;
          try {
            stored = localStorage.getItem('theme');
          } catch {}
          var theme =
            stored ||
            (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
          try {
            var palette = localStorage.getItem('palette');
            if (palette && palette !== 'original') document.documentElement.dataset.palette = palette;
            else delete document.documentElement.dataset.palette;
          } catch {}
        }
        apply();
        // Re-apply after View Transitions swap in a fresh <html>.
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
    <Seo {title} {description} {locale} {ogImage} {noindex} />
    <JsonLd {locale} />
    <ClientRouter />
  </head>
  <body class="flex min-h-svh flex-col">
    <SkipLink {locale} />
    {chrome && <Header {locale} />}
    <main id="main" class="flex-1">
      <slot />
    </main>
    {chrome && <Footer {locale} />}
    <script src="@/scripts/animations.ts"></script>

    <!-- palette-experiments branch only: floating palette switcher -->
    <div
      id="palette-switcher"
      style="position:fixed;bottom:1rem;left:1rem;z-index:60;display:flex;gap:.35rem;padding:.4rem .5rem;border:1px solid var(--line);border-radius:.6rem;background:var(--panel);font:600 .72rem/1 var(--font-mono)"
    >
      {
        ['original', 'indigo', 'forest', 'cobalt'].map((p) => (
          <button
            type="button"
            data-palette-pick={p}
            style="cursor:pointer;padding:.35rem .55rem;border-radius:.4rem;border:1px solid var(--line);color:var(--ink-muted);background:transparent"
          >
            {p}
          </button>
        ))
      }
    </div>
    <script>
      function initPaletteSwitcher() {
        document.querySelectorAll<HTMLElement>('[data-palette-pick]').forEach((btn) => {
          const pick = btn.dataset.palettePick!;
          const current = localStorage.getItem('palette') || 'original';
          btn.style.borderColor = current === pick ? 'var(--accent)' : 'var(--line)';
          btn.style.color = current === pick ? 'var(--accent)' : 'var(--ink-muted)';
          btn.onclick = () => {
            localStorage.setItem('palette', pick);
            if (pick === 'original') delete document.documentElement.dataset.palette;
            else document.documentElement.dataset.palette = pick;
            initPaletteSwitcher();
          };
        });
      }
      document.addEventListener('astro:page-load', initPaletteSwitcher);
    </script>
  </body>
</html>
