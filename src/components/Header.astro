---
import type { Locale } from '@/i18n/config';
import { localePath, useTranslations } from '@/i18n/utils';
import { site } from '@/data/site';
import ThemeToggle from '@/components/ThemeToggle.astro';
import Emblem from '@/components/ui/Emblem.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const home = localePath(locale, '/');

const nav = [
  { href: `${home}#projects`, label: t('nav.projects'), spy: 'projects' },
  { href: `${home}#about`, label: t('nav.about'), spy: 'about' },
  { href: `${home}#contact`, label: t('nav.contact'), spy: 'contact' },
];
---

<!-- technical band: hairline cells, bar-built wordmark, centered nav -->
<header class="border-line bg-surface/95 sticky top-0 z-40 border-b backdrop-blur-md">
  <div class="flex h-[5.25rem] items-stretch justify-between">
    <a href={home} class="group flex items-center gap-3.5 px-5 sm:px-7" aria-label="Ondřej Úlehla – home">
      <!-- rosette emblem (a-single-div "rosette-1") -->
      <Emblem
        class="text-accent size-9 shrink-0 transition-transform duration-500 ease-out group-hover:rotate-45"
      />
      <!-- ULEHLA built from bars (à la single-div lettering); bars slide apart on hover -->
      <span class="sd-mark" aria-hidden="true"></span>
      <span class="sr-only">ULEHLA</span>
    </a>

    <nav
      aria-label="Main"
      class="relative hidden flex-1 items-center justify-center gap-7 px-6 font-mono text-xs tracking-[0.14em] uppercase xl:flex"
    >
      <!-- sliding scrollspy underline – positioned by script -->
      <span class="nav-indicator" data-nav-indicator aria-hidden="true"></span>
      {
        nav.map((item) => (
          <a href={item.href} data-spy={item.spy} class="nav-roll text-ink-muted py-2">
            <span class="nav-roll__stack">
              <span>{item.label}</span>
              <span class="text-accent" aria-hidden="true">
                {item.label}
              </span>
            </span>
          </a>
        ))
      }
      <a
        href={localePath(locale, '/neural-network')}
        data-astro-prefetch="hover"
        data-route="/neural-network"
        class="nav-roll text-ink-muted py-2"
      >
        <span class="nav-roll__stack">
          <span>{t('nav.lab')}</span>
          <span class="text-accent" aria-hidden="true">{t('nav.lab')}</span>
        </span>
      </a>
      <a
        href={localePath(locale, '/playground')}
        data-astro-prefetch="hover"
        class="nav-roll group/pg text-accent inline-flex items-center gap-2 py-2 font-semibold"
      >
        <!-- rotated-square marker: a shard of the quilt-star emblem -->
        <span
          class="border-accent inline-block size-2 rotate-45 border transition-transform duration-500 ease-out group-hover/pg:rotate-[225deg]"
          aria-hidden="true"></span>
        <span class="nav-roll__stack">
          <span>{t('nav.playground')}</span>
          <span class="text-ink" aria-hidden="true">{t('nav.playground')}</span>
        </span>
      </a>
    </nav>

    <div class="flex items-stretch">
      <div class="flex items-stretch">
        <ThemeToggle {locale} />
        <details class="relative flex xl:hidden" data-mobile-menu>
          <summary
            class="cell-flood border-line flex w-16 cursor-pointer list-none items-center justify-center border-l [&::-webkit-details-marker]:hidden"
            aria-label={t('nav.menu')}
          >
            <svg
              class="size-4.5"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M4 7h16M4 12h16M4 17h16"></path>
            </svg>
          </summary>
          <nav
            aria-label="Mobile"
            class="border-line bg-panel absolute top-full right-0 z-50 flex w-52 flex-col gap-1 border p-2 shadow-xl"
          >
            {
              [
                ...nav,
                { href: localePath(locale, '/neural-network'), label: t('nav.lab') },
                { href: localePath(locale, '/playground'), label: t('nav.playground') },
              ].map((item) => (
                <a
                  href={item.href}
                  class="text-ink-muted hover:bg-surface hover:text-ink px-3 py-2 text-sm font-medium"
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </details>
      </div>

      <!-- socials: square cells that flood with ink on hover -->
      <div class="hidden items-stretch sm:flex" role="list">
        <a
          href={site.github}
          rel="me noopener"
          target="_blank"
          class="cell-flood border-line flex w-16 items-center justify-center border-l"
          aria-label="GitHub"
        >
          <svg class="size-4.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            ></path>
          </svg>
        </a>
        <a
          href={site.linkedin}
          rel="me noopener"
          target="_blank"
          class="cell-flood border-line flex w-16 items-center justify-center border-l"
          aria-label="LinkedIn"
        >
          <svg class="size-4.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"
            ></path>
          </svg>
        </a>
        <a
          href={`mailto:${site.email}`}
          class="cell-flood border-line flex w-16 items-center justify-center border-l"
          aria-label="E-mail"
        >
          <svg class="size-4.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z"
            ></path>
            <path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  /* ULEHLA from 5px bars – one span, 18 gradient layers */
  .sd-mark {
    width: 115px;
    height: 25px;
    background-image:
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink)),
      linear-gradient(var(--ink), var(--ink));
    background-repeat: no-repeat;
    /* U: cols + bottom | L: col + bottom | E: col + 3 rows | H: 2 cols + mid | L | A: 2 cols + top + mid */
    background-size:
      5px 25px, 5px 25px, 15px 5px,
      5px 25px, 15px 5px,
      5px 25px, 15px 5px, 15px 5px, 15px 5px,
      5px 25px, 5px 25px, 15px 5px,
      5px 25px, 15px 5px,
      5px 25px, 5px 25px, 15px 5px, 15px 5px,
      0px 0px, 0px 0px, 0px 0px, 0px 0px, 0px 0px;
    background-position:
      0 0, 10px 0, 0 20px,
      20px 0, 20px 20px,
      40px 0, 40px 0, 40px 10px, 40px 20px,
      60px 0, 70px 0, 60px 10px,
      80px 0, 80px 20px,
      100px 0, 110px 0, 100px 0, 100px 10px,
      50px 5px, 70px 15px, 0px 0px, 80px 0px, 100px 20px;
    transition:
      background-position 0.45s cubic-bezier(0.76, 0, 0.24, 1),
      background-size 0.45s cubic-bezier(0.76, 0, 0.24, 1);
  }
  /* fin->ten trick, our way: on hover the bars recompose into ONDREJ */
  a:hover .sd-mark,
  a:focus-visible .sd-mark {
    background-size:
      5px 25px, 5px 25px, 15px 5px,
      5px 25px, 15px 5px,
      5px 25px, 15px 5px, 10px 5px, 15px 5px,
      5px 25px, 5px 5px, 15px 5px,
      5px 25px, 15px 5px,
      5px 25px, 5px 25px, 10px 5px, 15px 5px,
      5px 15px, 5px 10px, 15px 5px, 15px 5px, 10px 5px;
    background-position:
      0 0, 10px 0, 0 20px,
      20px 0, 20px 0,
      40px 0, 40px 0, 60px 10px, 40px 20px,
      60px 0, 70px 5px, 60px 0,
      80px 0, 80px 20px,
      30px 0, 110px 0, 105px 0, 80px 10px,
      50px 5px, 70px 15px, 0px 0px, 80px 0px, 100px 20px;
  }

  /* nav labels roll up on hover, accent copy rolls in */
  .nav-roll__stack {
    display: inline-flex;
    flex-direction: column;
    overflow: hidden;
    height: 1.1em;
    line-height: 1.1;
  }
  .nav-roll__stack span {
    transition: transform 0.32s cubic-bezier(0.76, 0, 0.24, 1);
  }
  .nav-roll:hover .nav-roll__stack span,
  .nav-roll:focus-visible .nav-roll__stack span {
    transform: translateY(-100%);
  }

  /* scrollspy / current route: accent label, underline slides between items.
     The active item is a "you are here" state, not an action – rolling to an
     identical accent copy would communicate nothing, so it doesn't roll. */
  .nav-roll[data-active] {
    color: var(--accent);
  }
  .nav-roll[data-active]:hover .nav-roll__stack span,
  .nav-roll[data-active]:focus-visible .nav-roll__stack span {
    transform: none;
  }
  .nav-indicator {
    position: absolute;
    top: calc(50% + 0.85em);
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    opacity: 0;
    transition:
      transform 0.4s cubic-bezier(0.76, 0, 0.24, 1),
      width 0.4s cubic-bezier(0.76, 0, 0.24, 1),
      opacity 0.25s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-indicator {
      transition: opacity 0.25s ease;
    }
  }
</style>

<script>
  // Close the mobile menu after a selection or outside click.
  function initMenu() {
    document.querySelectorAll<HTMLDetailsElement>('[data-mobile-menu]').forEach((menu) => {
      if (menu.dataset.bound) return;
      menu.dataset.bound = 'true';
      menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => (menu.open = false)));
      document.addEventListener('click', (e) => {
        if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
      });
    });
  }
  initMenu();
  document.addEventListener('astro:page-load', initMenu);

  // Scrollspy: highlight the nav item of the section crossing the viewport's
  // upper third (homepage only); route links highlight on their own page.
  // Sections without their own nav item roll up under the nearest one.
  const SPY_MAP: Record<string, string> = {
    projects: 'projects',
    about: 'about',
    experience: 'about',
    education: 'about',
    skills: 'about',
    contact: 'contact',
  };
  let spyObserver: IntersectionObserver | undefined;
  let activeLink: HTMLElement | null = null;
  let spyLinks: HTMLElement[] = [];
  let spySections: HTMLElement[] = [];
  let bandCurrent: string | undefined;
  // clicking a nav link highlights it immediately and pins it while the
  // smooth scroll is in flight – otherwise the underline would crawl
  // through every section on the way down
  let clickLock: string | undefined;
  let clickLockTimer: ReturnType<typeof setTimeout> | undefined;

  // the accent underline slides between nav items, sized to the label text
  // (not the whole link, which carries tracking space and the ◇ marker)
  function positionIndicator(target: HTMLElement | null) {
    const bar = document.querySelector<HTMLElement>('[data-nav-indicator]');
    if (!bar) return;
    activeLink = target;
    if (!target || !target.offsetParent) {
      bar.style.opacity = '0';
      return;
    }
    const stack = target.querySelector<HTMLElement>('.nav-roll__stack') ?? target;
    const tracking = parseFloat(getComputedStyle(stack).letterSpacing) || 0;
    // sub-pixel rects (offsetLeft/Width round to integers and drift by ±1px)
    const navRect = bar.parentElement!.getBoundingClientRect();
    const rect = stack.getBoundingClientRect();
    bar.style.opacity = '1';
    bar.style.width = `${rect.width - tracking}px`;
    bar.style.transform = `translateX(${rect.left - navRect.left}px)`;
  }

  // the active section: a clicked link wins while its scroll is in flight,
  // then whatever crosses the band – except at the very bottom of the page,
  // where the last (short) section could never reach it
  function applyActive() {
    const atBottom =
      innerHeight + scrollY >= document.documentElement.scrollHeight - 8;
    const current =
      clickLock ??
      (atBottom && spySections.length
        ? SPY_MAP[spySections[spySections.length - 1]!.id]
        : bandCurrent);
    let target: HTMLElement | null = null;
    spyLinks.forEach((l) => {
      const active = l.dataset.spy === current;
      l.toggleAttribute('data-active', active);
      if (active) target = l;
    });
    positionIndicator(target);
  }

  function initSpy() {
    spyLinks = [...document.querySelectorAll<HTMLElement>('[data-spy]')];
    const routeLinks = [...document.querySelectorAll<HTMLElement>('[data-route]')];
    const path = location.pathname.replace(/\/$/, '') || '/';
    routeLinks.forEach((l) => l.toggleAttribute('data-active', l.dataset.route === path));

    spyObserver?.disconnect();
    bandCurrent = undefined;
    spySections = [...document.querySelectorAll<HTMLElement>('section[id]')].filter(
      (s) => SPY_MAP[s.id],
    );

    // hash navigation (nav clicks included) re-runs initSpy mid-scroll – the
    // pin must survive it, or the underline parks on whatever passes the band
    clickLock =
      spySections.length && SPY_MAP[location.hash.slice(1)]
        ? SPY_MAP[location.hash.slice(1)]
        : undefined;

    if (clickLock) {
      applyActive();
    } else {
      spyLinks.forEach((l) => l.removeAttribute('data-active'));
      positionIndicator(routeLinks.find((l) => l.hasAttribute('data-active')) ?? null);
    }

    spyLinks.forEach((l) => {
      if (l.dataset.lockBound) return;
      l.dataset.lockBound = '1';
      l.addEventListener('click', () => {
        if (!spySections.length) return; // navigating from a subpage instead
        clickLock = l.dataset.spy;
        applyActive();
      });
    });

    if (!spySections.length) return;

    const inBand = new Set<string>();
    spyObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) inBand.add(entry.target.id);
          else inBand.delete(entry.target.id);
        }
        // first intersecting section in document order; none → nothing lit
        const section = spySections.find((s) => inBand.has(s.id));
        bandCurrent = section ? SPY_MAP[section.id] : undefined;
        applyActive();
      },
      { rootMargin: '-30% 0px -60% 0px' },
    );
    spySections.forEach((s) => spyObserver!.observe(s));
  }
  initSpy();
  document.addEventListener('astro:page-load', initSpy);
  addEventListener(
    'scroll',
    () => {
      if (!spySections.length) return;
      // release the click pin once the smooth scroll has settled
      if (clickLock) {
        clearTimeout(clickLockTimer);
        clickLockTimer = setTimeout(() => {
          clickLock = undefined;
          applyActive();
        }, 200);
      }
      applyActive();
    },
    { passive: true },
  );
  addEventListener('resize', () => positionIndicator(activeLink));
</script>
