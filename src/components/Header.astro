---
import type { Locale } from '@/i18n/config';
import { localePath, useTranslations } from '@/i18n/utils';
import ThemeToggle from '@/components/ThemeToggle.astro';
import LangSwitcher from '@/components/LangSwitcher.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const home = localePath(locale, '/');

const nav = [
  { href: `${home}#about`, label: t('nav.about') },
  { href: `${home}#experience`, label: t('nav.experience') },
  { href: `${home}#projects`, label: t('nav.projects') },
  { href: `${home}#contact`, label: t('nav.contact') },
];
---

<!-- technical band: full-width cells separated by hairlines, like a printed spec sheet -->
<header class="border-line bg-surface/95 sticky top-0 z-40 border-b backdrop-blur-md">
  <div class="flex items-stretch">
    <a
      href={home}
      class="font-poster text-ink hover:text-accent flex items-center px-5 text-[1.35rem] transition-colors sm:px-7"
      aria-label="Ondřej Úlehla – home"
    >
      ULEHLA
    </a>

    <div class="border-line hatch my-3 hidden flex-1 border-x md:block" role="presentation"></div>

    <nav
      aria-label="Main"
      class="hidden items-center gap-7 px-7 font-mono text-xs tracking-[0.14em] uppercase lg:flex"
    >
      {
        nav.map((item) => (
          <a href={item.href} class="text-ink-muted hover:text-ink py-2 transition-colors">
            {item.label}
          </a>
        ))
      }
      <a
        href={localePath(locale, '/neural-network')}
        data-astro-prefetch="hover"
        class="text-ink-muted hover:text-ink py-2 transition-colors"
      >
        {t('nav.lab')}
      </a>
      <a
        href={localePath(locale, '/playground')}
        data-astro-prefetch="hover"
        class="text-accent hover:text-accent-strong inline-flex items-center gap-1.5 py-2 font-semibold transition-colors"
      >
        <span class="bg-accent inline-block size-1.5" aria-hidden="true"></span>
        {t('nav.playground')}
      </a>
    </nav>

    <div class="border-line flex items-center gap-2 border-l px-4">
      <LangSwitcher {locale} />
      <ThemeToggle {locale} />
      <details class="relative lg:hidden" data-mobile-menu>
        <summary
          class="border-line text-ink-muted hover:text-ink flex size-9 cursor-pointer list-none items-center justify-center rounded-full border [&::-webkit-details-marker]:hidden"
          aria-label={t('nav.menu')}
        >
          <svg
            class="size-4"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <path d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </summary>
        <nav
          aria-label="Mobile"
          class="border-line bg-panel absolute top-12 right-0 z-50 flex w-52 flex-col gap-1 rounded-xl border p-2 shadow-xl"
        >
          {
            [
              ...nav,
              { href: localePath(locale, '/neural-network'), label: t('nav.lab') },
              { href: localePath(locale, '/playground'), label: t('nav.playground') },
            ].map((item) => (
              <a
                href={item.href}
                class="text-ink-muted hover:bg-surface hover:text-ink rounded-lg px-3 py-2 text-sm font-medium"
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </details>
    </div>

    <aside class="border-line hidden flex-col justify-center divide-y divide-[var(--line)] border-l xl:flex">
      <p class="text-ink-faint px-5 py-1.5 text-xs">{t('header.line1')}</p>
      <p class="text-ink-muted px-5 py-1.5 text-xs">
        {t('header.line2')}
        <a href={`${home}#contact`} class="text-accent hover:text-accent-strong font-semibold transition-colors">
          → {t('header.hire')}
        </a>
      </p>
    </aside>
  </div>
</header>

<script>
  // Close the mobile menu after a selection or outside click.
  function initMenu() {
    document.querySelectorAll<HTMLDetailsElement>('[data-mobile-menu]').forEach((menu) => {
      if (menu.dataset.bound) return;
      menu.dataset.bound = 'true';
      menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => (menu.open = false)));
      document.addEventListener('click', (e) => {
        if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
      });
    });
  }
  initMenu();
  document.addEventListener('astro:page-load', initMenu);
</script>
