---
import type { Locale } from '@/i18n/config';
import { localePath, useTranslations } from '@/i18n/utils';
import ThemeToggle from '@/components/ThemeToggle.astro';
import LangSwitcher from '@/components/LangSwitcher.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const home = localePath(locale, '/');

const nav = [
  { href: `${home}#about`, label: t('nav.about') },
  { href: `${home}#experience`, label: t('nav.experience') },
  { href: `${home}#projects`, label: t('nav.projects') },
  { href: `${home}#contact`, label: t('nav.contact') },
];
---

<header class="border-line/60 bg-surface/80 sticky top-0 z-40 border-b backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8">
    <a
      href={home}
      class="font-display text-ink text-lg font-bold tracking-tight"
      aria-label="Ondřej Úlehla – home"
    >
      OU<span class="text-accent">.</span>
    </a>

    <nav aria-label="Main" class="hidden items-center gap-7 md:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-ink-muted hover:text-ink text-sm font-medium transition-colors"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={localePath(locale, '/neural-network')}
        data-astro-prefetch="hover"
        class="text-ink-muted hover:text-ink text-sm font-medium transition-colors"
      >
        {t('nav.lab')}
      </a>
      <a
        href={localePath(locale, '/playground')}
        data-astro-prefetch="hover"
        class="text-accent hover:text-accent-strong inline-flex items-center gap-1.5 text-sm font-semibold transition-colors"
      >
        <span class="bg-accent inline-block size-1.5" aria-hidden="true"></span>
        {t('nav.playground')}
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <LangSwitcher {locale} />
      <ThemeToggle {locale} />
      <details class="relative md:hidden" data-mobile-menu>
        <summary
          class="border-line text-ink-muted hover:text-ink flex size-9 cursor-pointer list-none items-center justify-center rounded-full border [&::-webkit-details-marker]:hidden"
          aria-label={t('nav.menu')}
        >
          <svg
            class="size-4"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <path d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </summary>
        <nav
          aria-label="Mobile"
          class="border-line bg-panel absolute top-12 right-0 z-50 flex w-52 flex-col gap-1 rounded-xl border p-2 shadow-xl"
        >
          {
            [
              ...nav,
              { href: localePath(locale, '/neural-network'), label: t('nav.lab') },
              { href: localePath(locale, '/playground'), label: t('nav.playground') },
            ].map(
              (item) => (
                <a
                  href={item.href}
                  class="text-ink-muted hover:bg-surface hover:text-ink rounded-lg px-3 py-2 text-sm font-medium"
                >
                  {item.label}
                </a>
              ),
            )
          }
        </nav>
      </details>
    </div>
  </div>
</header>

<script>
  // Close the mobile menu after a selection or outside click.
  function initMenu() {
    document.querySelectorAll<HTMLDetailsElement>('[data-mobile-menu]').forEach((menu) => {
      if (menu.dataset.bound) return;
      menu.dataset.bound = 'true';
      menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => (menu.open = false)));
      document.addEventListener('click', (e) => {
        if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
      });
    });
  }
  initMenu();
  document.addEventListener('astro:page-load', initMenu);
</script>
