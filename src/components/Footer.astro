---
import type { Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/utils';
import { site } from '@/data/site';
import Emblem from '@/components/ui/Emblem.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<!-- technical band mirroring the header: hairline cells, ink-flood hover -->
<footer class="border-line border-t">
  <div class="flex items-stretch justify-between">
    <a
      href="/"
      class="group flex items-center gap-3 px-5 py-4 sm:px-7"
      aria-label="Ondřej Úlehla – home"
    >
      <Emblem
        class="text-accent size-6 shrink-0 transition-transform duration-500 ease-out group-hover:rotate-45"
      />
      <span class="text-ink-muted font-mono text-xs tracking-[0.12em] uppercase">
        © {year} Ondřej Úlehla
      </span>
    </a>

    <p class="text-ink-faint hidden items-center px-6 font-mono text-xs md:flex">
      {t('footer.built')}
    </p>

    <!-- three equal cells, together exactly as wide as the header's four
         w-16 cells (w-64), so both blocks share the same left edge -->
    <div class="flex items-stretch font-mono text-xs tracking-[0.15em] uppercase sm:grid sm:w-64 sm:grid-cols-3">
      <a
        href={site.github}
        rel="me noopener"
        target="_blank"
        class="cell-flood border-line hidden items-center justify-center border-l sm:flex"
      >
        GitHub
      </a>
      <a
        href={site.linkedin}
        rel="me noopener"
        target="_blank"
        class="cell-flood border-line hidden items-center justify-center border-l sm:flex"
      >
        LinkedIn
      </a>
      <a
        href={`mailto:${site.email}`}
        class="cell-flood border-line flex items-center justify-center border-l px-5 sm:px-0"
      >
        E-mail
      </a>
    </div>
  </div>
</footer>
