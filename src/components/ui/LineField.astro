---
/**
 * Interactive field of fine vertical lines. A slow Perlin flow braids the
 * lines into coherent wave shapes even before any interaction; the cursor
 * then pushes into that fabric with spring physics (impulse along the
 * pointer's direction of travel, scaled by its velocity). A small ink dot
 * trails the smoothed cursor. Pure 2D canvas, theme-aware, static under
 * prefers-reduced-motion.
 */
---

<div class="pointer-events-none absolute inset-0" data-linefield-wrap aria-hidden="true">
  <canvas data-linefield class="h-full w-full"></canvas>
</div>

<script>
  import { liteMotion } from '@/scripts/motion';

  interface Point {
    x: number;
    y: number;
    wx: number;
    wy: number;
    cx: number;
    cy: number;
    vx: number;
    vy: number;
  }

  // --- classic 2D Perlin gradient noise, deterministic seed ------------------
  const PERM = (() => {
    const base = new Uint8Array(256);
    for (let i = 0; i < 256; i++) base[i] = i;
    let seed = 1996;
    const rnd = () => (seed = (seed * 16807) % 2147483647) / 2147483647;
    for (let i = 255; i > 0; i--) {
      const j = Math.floor(rnd() * (i + 1));
      [base[i], base[j]] = [base[j]!, base[i]!];
    }
    const p = new Uint8Array(512);
    for (let i = 0; i < 512; i++) p[i] = base[i & 255]!;
    return p;
  })();
  const fade = (t: number) => t * t * t * (t * (t * 6 - 15) + 10);
  const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
  const grad2 = (h: number, x: number, y: number) => {
    switch (h & 7) {
      case 0:
        return x + y;
      case 1:
        return -x + y;
      case 2:
        return x - y;
      case 3:
        return -x - y;
      case 4:
        return x;
      case 5:
        return -x;
      case 6:
        return y;
      default:
        return -y;
    }
  };
  function perlin2(x: number, y: number): number {
    const X = Math.floor(x) & 255;
    const Y = Math.floor(y) & 255;
    const xf = x - Math.floor(x);
    const yf = y - Math.floor(y);
    const u = fade(xf);
    const v = fade(yf);
    const aa = PERM[PERM[X]! + Y]!;
    const ab = PERM[PERM[X]! + Y + 1]!;
    const ba = PERM[PERM[X + 1]! + Y]!;
    const bb = PERM[PERM[X + 1]! + Y + 1]!;
    return lerp(
      lerp(grad2(aa, xf, yf), grad2(ba, xf - 1, yf), u),
      lerp(grad2(ab, xf, yf - 1), grad2(bb, xf - 1, yf - 1), u),
      v,
    );
  }

  function initLineField(wrap: HTMLElement) {
    if (wrap.dataset.bound) return;
    wrap.dataset.bound = '1';

    const canvas = wrap.querySelector<HTMLCanvasElement>('[data-linefield]')!;
    const ctx = canvas.getContext('2d')!;
    // touch devices get the same single static frame as reduced-motion users:
    // the whole effect is cursor-driven, so on a phone it is pure frame cost
    const reduced = liteMotion();
    const X_GAP = 10;
    const Y_GAP = 32;

    let lines: Point[][] = [];
    let w = 0;
    let h = 0;
    let dpr = 1;
    let stroke = 'rgba(0,0,0,0.14)';
    let raf = 0;

    const mouse = { x: -1e4, y: -1e4, sx: -1e4, sy: -1e4, lx: 0, ly: 0, v: 0, vs: 0, a: 0, set: false };

    function readColor() {
      const css = getComputedStyle(document.documentElement);
      const dark = document.documentElement.dataset.theme === 'dark';
      const ink = css.getPropertyValue('--ink-faint').trim() || '#777';
      stroke = `color-mix(in oklab, ${ink} ${dark ? 46 : 40}%, transparent)`;
    }

    function resize() {
      const rect = canvas.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      dpr = Math.min(devicePixelRatio || 1, 2);
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      buildLines();
    }

    function buildLines() {
      lines = [];
      const oWidth = w + 200;
      const oHeight = h + 60;
      const totalLines = Math.ceil(oWidth / X_GAP);
      const totalPoints = Math.ceil(oHeight / Y_GAP) + 1;
      const x0 = (w - X_GAP * totalLines) / 2;
      const y0 = (h - Y_GAP * (totalPoints - 1)) / 2;
      for (let i = 0; i <= totalLines; i++) {
        const pts: Point[] = [];
        for (let j = 0; j < totalPoints; j++) {
          pts.push({ x: x0 + i * X_GAP, y: y0 + j * Y_GAP, wx: 0, wy: 0, cx: 0, cy: 0, vx: 0, vy: 0 });
        }
        lines.push(pts);
      }
    }

    function movePoints(t: number) {
      const radius = Math.max(175, mouse.vs);
      for (const pts of lines) {
        for (const p of pts) {
          // Perlin flow braids the lines into travelling wave shapes
          const move = perlin2((p.x + t * 0.0125) * 0.002, (p.y + t * 0.005) * 0.0015) * 12;
          p.wx = Math.cos(move) * 32;
          p.wy = Math.sin(move) * 16;

          // cursor impulse along the pointer's travel direction
          const dx = p.x - mouse.sx;
          const dy = p.y - mouse.sy;
          const d = Math.hypot(dx, dy);
          if (d < radius) {
            const s = 1 - d / radius;
            const f = Math.cos(d * 0.001) * s;
            p.vx += Math.cos(mouse.a) * f * radius * mouse.vs * 0.00065;
            p.vy += Math.sin(mouse.a) * f * radius * mouse.vs * 0.00065;
          }

          // spring back + friction
          p.vx += -p.cx * 0.005;
          p.vy += -p.cy * 0.005;
          p.vx *= 0.925;
          p.vy *= 0.925;
          p.cx = Math.min(100, Math.max(-100, p.cx + p.vx * 2));
          p.cy = Math.min(100, Math.max(-100, p.cy + p.vy * 2));
        }
      }
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);
      ctx.strokeStyle = stroke;
      ctx.lineWidth = 1;
      ctx.lineJoin = 'round';
      ctx.lineCap = 'round';
      for (const pts of lines) {
        // resolve the displaced positions once, then thread a curve through
        // them: each segment is a quadratic with the sample point as its
        // control and the midpoint as its end, so consecutive segments share
        // tangents – no corners even when the cursor bends a line hard
        const px: number[] = [];
        const py: number[] = [];
        for (let j = 0; j < pts.length; j++) {
          const p = pts[j]!;
          const isLast = j === pts.length - 1;
          px.push(p.x + p.wx + (isLast ? 0 : p.cx));
          py.push(p.y + p.wy + (isLast ? 0 : p.cy));
        }
        ctx.beginPath();
        ctx.moveTo(px[0]!, py[0]!);
        for (let j = 1; j < pts.length - 1; j++) {
          ctx.quadraticCurveTo(px[j]!, py[j]!, (px[j]! + px[j + 1]!) / 2, (py[j]! + py[j + 1]!) / 2);
        }
        ctx.lineTo(px[pts.length - 1]!, py[pts.length - 1]!);
        ctx.stroke();
      }
    }

    function tick(t: number) {
      mouse.sx += (mouse.x - mouse.sx) * 0.1;
      mouse.sy += (mouse.y - mouse.sy) * 0.1;
      const dx = mouse.x - mouse.lx;
      const dy = mouse.y - mouse.ly;
      const d = Math.hypot(dx, dy);
      mouse.v = d;
      mouse.vs += (d - mouse.vs) * 0.1;
      mouse.vs = Math.min(100, mouse.vs);
      mouse.lx = mouse.x;
      mouse.ly = mouse.y;
      if (d > 0.05) mouse.a = Math.atan2(dy, dx);

      movePoints(t);
      draw();
      raf = requestAnimationFrame(tick);
    }

    function onPointer(x: number, y: number) {
      const rect = canvas.getBoundingClientRect();
      // pointer outside the field (e.g. over the sticky header) must not stir it
      if (x < rect.left || x > rect.right || y < rect.top || y > rect.bottom) {
        mouse.x = -1e4;
        mouse.y = -1e4;
        return;
      }
      mouse.x = x - rect.left;
      mouse.y = y - rect.top;
      if (!mouse.set) {
        mouse.sx = mouse.x;
        mouse.sy = mouse.y;
        mouse.lx = mouse.x;
        mouse.ly = mouse.y;
        mouse.set = true;
      }
    }
    const onMouseMove = (e: MouseEvent) => onPointer(e.clientX, e.clientY);
    const onTouchMove = (e: TouchEvent) => {
      const t = e.touches[0];
      if (t) onPointer(t.clientX, t.clientY);
    };

    readColor();
    resize();

    if (reduced) {
      movePoints(1200);
      draw();
    } else {
      window.addEventListener('mousemove', onMouseMove, { passive: true });
      window.addEventListener('touchmove', onTouchMove, { passive: true });
      raf = requestAnimationFrame(tick);
    }

    const ro = new ResizeObserver(() => {
      resize();
      if (reduced) {
        movePoints(1200);
        draw();
      }
    });
    ro.observe(canvas);

    const themeObserver = new MutationObserver(() => {
      readColor();
      if (reduced) draw();
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme', 'data-palette'],
    });

    document.addEventListener(
      'astro:before-swap',
      () => {
        cancelAnimationFrame(raf);
        window.removeEventListener('mousemove', onMouseMove);
        window.removeEventListener('touchmove', onTouchMove);
        ro.disconnect();
        themeObserver.disconnect();
      },
      { once: true },
    );
  }

  function initAll() {
    document.querySelectorAll<HTMLElement>('[data-linefield-wrap]').forEach(initLineField);
  }
  initAll();
  document.addEventListener('astro:page-load', initAll);
</script>
