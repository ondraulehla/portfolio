---
interface Props {
  id?: string;
  kicker: string;
  heading: string;
}
const { id, kicker, heading } = Astro.props;
---

<div class="border-line mb-12 border-t pt-5" data-reveal>
  <p class="text-accent font-mono text-xs font-semibold tracking-[0.2em] uppercase">
    {kicker}
  </p>
  <h2 {id} class="font-poster text-ink mt-3 text-4xl sm:text-5xl">
    {heading}
  </h2>
</div>
