---
interface Props {
  id?: string;
  heading: string;
}
const { id, heading } = Astro.props;
---

<!-- poster heading with an accent particle trail behind it (after wodniack's Rainbow pen) -->
<div class="relative mb-12" data-reveal data-heading-fx>
  <canvas
    class="pointer-events-none absolute -top-16 -left-10 z-0 h-[calc(100%+8rem)] w-[calc(100%+5rem)]"
    aria-hidden="true"></canvas>
  <h2 {id} class="font-poster text-accent relative z-10 text-4xl sm:text-5xl">
    {heading}
  </h2>
</div>

<script>
  /** Accent-graded particles that trail the cursor across a section heading. */
  function initHeadingFx() {
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced || matchMedia('(hover: none)').matches) return;

    document.querySelectorAll<HTMLElement>('[data-heading-fx]').forEach((host) => {
      if (host.dataset.bound) return;
      host.dataset.bound = '1';

      const canvas = host.querySelector('canvas')!;
      const ctx = canvas.getContext('2d')!;

      type P = { x: number; y: number; vx: number; vy: number; size: number; seed: number; freq: number; amp: number; l: number };
      const particles: P[] = [];
      const mouse = { x: 0, y: 0, sx: 0, sy: 0, vx: 0, vy: 0, svx: 0, svy: 0, in: false };
      let cnt = 0;
      let dpr = 1;
      let running = false;

      // grade the accent colour by cycling its oklch lightness
      let accentL = 55;
      let accentC = '0.2';
      let accentH = '33';
      function readAccent() {
        const raw = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim();
        const m = raw.match(/oklch\(\s*([\d.]+)%\s+([\d.]+)\s+([\d.]+)/);
        if (m) {
          accentL = parseFloat(m[1]!);
          accentC = m[2]!;
          accentH = m[3]!;
        }
      }

      function resize() {
        dpr = Math.min(devicePixelRatio || 1, 2);
        canvas.width = canvas.offsetWidth * dpr;
        canvas.height = canvas.offsetHeight * dpr;
      }
      resize();
      addEventListener('resize', resize);

      function frame(time: number) {
        mouse.sx += (mouse.x - mouse.sx) * 0.1;
        mouse.sy += (mouse.y - mouse.sy) * 0.1;
        mouse.svx += (mouse.vx - mouse.svx) * 0.1;
        mouse.svy += (mouse.vy - mouse.svy) * 0.1;
        mouse.vx *= 0.85;
        mouse.vy *= 0.85;

        // emit along the smoothed trail while the pointer is moving over the heading
        const diff = Math.hypot(mouse.x - mouse.sx, mouse.y - mouse.sy);
        if (mouse.in && diff > 0.5) {
          cnt += 5;
          particles.push({
            x: mouse.sx,
            y: mouse.sy,
            vx: mouse.svx * -0.25,
            vy: mouse.svy * -0.25,
            size: Math.min(diff * 0.28, 15),
            seed: Math.random() * 1000,
            freq: (0.5 + Math.random()) * 0.01,
            amp: (1 - Math.random() * 2) * 0.5,
            l: accentL - 12 + (cnt % 32), // graded accent lightness
          });
        }

        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.clearRect(0, 0, canvas.offsetWidth, canvas.offsetHeight);

        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i]!;
          p.x += Math.cos((time + p.seed) * p.freq) * p.amp + p.vx;
          p.y += Math.sin((time + p.seed) * p.freq) * p.amp + p.vy;
          p.vx *= 0.95;
          p.vy *= 0.95;
          p.size += Math.hypot(p.vx, p.vy);
          p.size *= 0.85;
          if (p.size < 0.8) {
            particles.splice(i, 1);
            continue;
          }
          ctx.fillStyle = `oklch(${p.l}% ${accentC} ${accentH})`;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fill();
        }

        if (!particles.length && !mouse.in) {
          running = false;
          return;
        }
        requestAnimationFrame(frame);
      }

      function kick() {
        if (!running) {
          running = true;
          readAccent();
          requestAnimationFrame(frame);
        }
      }

      host.addEventListener('pointermove', (e) => {
        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        mouse.vx += mouse.x - x;
        mouse.vy += mouse.y - y;
        mouse.x = x;
        mouse.y = y;
        if (!mouse.in) {
          mouse.in = true;
          mouse.sx = x;
          mouse.sy = y;
        }
        kick();
      });
      host.addEventListener('pointerleave', () => {
        mouse.in = false;
      });
    });
  }

  initHeadingFx();
  document.addEventListener('astro:page-load', initHeadingFx);
</script>
