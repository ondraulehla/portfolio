---
import { locales, type Locale } from '@/i18n/config';
import { switchLocalePath } from '@/i18n/utils';
import { site } from '@/data/site';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, locale, ogImage, noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const image = new URL(ogImage ?? `/og/default-${locale}.png`, Astro.site);
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex" />}

{
  locales.map((l) => (
    <link rel="alternate" hreflang={l} href={new URL(switchLocalePath(Astro.url, l), Astro.site)} />
  ))
}
<link rel="alternate" hreflang="x-default" href={new URL(switchLocalePath(Astro.url, 'en'), Astro.site)} />

<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={image} />
<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content={site.name} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />
