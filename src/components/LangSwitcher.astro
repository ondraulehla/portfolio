---
import type { Locale } from '@/i18n/config';
import { otherLocale, switchLocalePath, useTranslations } from '@/i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const target = otherLocale(locale);
const href = switchLocalePath(Astro.url, target);
---

<a
  {href}
  aria-label={t('lang.switch')}
  data-astro-prefetch="hover"
  class="cell-flood border-line flex w-14 items-center justify-center border-l font-mono text-xs font-bold tracking-[0.15em]"
>
  {t('lang.switchShort')}
</a>
