---
import type { Locale } from '@/i18n/config';
import { localePath, useTranslations } from '@/i18n/utils';
import { site } from '@/data/site';
import Button from '@/components/ui/Button.astro';
import LineField from '@/components/ui/LineField.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

/** decorative binary for the spec tape – deterministic, no runtime cost */
const bits = '01001111 01010101 00101110 01000100 01000101 01010110';
---

<section class="border-line/70 relative overflow-hidden border-b">
  <!-- interactive line field: fine engraved verticals bending away from the cursor -->
  <div class="absolute inset-x-0 top-0 bottom-24 [mask-image:linear-gradient(to_bottom,black_58%,transparent_100%)]">
    <LineField />
  </div>

  <div class="relative mx-auto max-w-6xl px-5 sm:px-8">
    <!-- masthead: technical spec tape -->
    <div
      class="hero-rise text-ink-faint flex flex-wrap items-center justify-between gap-x-6 gap-y-2 border-b border-dashed border-[var(--line)] py-4 font-mono text-xs tracking-wide uppercase"
    >
      <span>{site.name}</span>
      <span class="hidden items-center gap-3 md:flex" aria-hidden="true">
        <span class="tracking-[0.3em] opacity-70">{bits}</span>
        <span class="opacity-70">{'/'.repeat(24)}</span>
      </span>
      <span>{site.location[locale]}</span>
    </div>

    <div class="pt-14 pb-16 sm:pt-20 sm:pb-24">
      <h1 class="hero-rise font-poster text-ink text-[length:var(--text-fluid-poster)] leading-[0.92]" data-hero-title>
        {t('hero.title.line1')}<br />
        <span class="text-accent inline-flex items-baseline gap-[0.18em]">
          <svg
            class="h-[0.44em] w-[0.44em] translate-y-[-0.06em]"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M12 0c1.4 7.1 4.9 10.6 12 12-7.1 1.4-10.6 4.9-12 12-1.4-7.1-4.9-10.6-12-12C7.1 10.6 10.6 7.1 12 0Z"
            ></path>
          </svg>
          {t('hero.title.line2')}
        </span>
      </h1>

      <p class="hero-rise-late text-ink-muted mt-9 max-w-2xl text-lg leading-relaxed text-balance sm:text-xl">
        {t('hero.subtitle')}
      </p>

      <div class="hero-rise-late mt-10 flex flex-wrap items-center gap-3">
        <Button href={`${localePath(locale, '/')}#projects`} variant="primary">
          {t('hero.cta.projects')}
          <svg
            class="size-4 transition-transform group-hover:translate-y-0.5"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="M12 5v14m-7-7 7 7 7-7"></path></svg
          >
        </Button>
        <Button href={`/cv/ondrej-ulehla-${locale}.pdf`} variant="secondary" download>
          {t('hero.cta.cv')}
        </Button>
        <Button href={localePath(locale, '/playground')} variant="ghost" prefetch>
          {t('hero.cta.playground')}
          <svg
            class="size-4 transition-transform group-hover:translate-x-0.5"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="M5 12h14m-7-7 7 7-7 7"></path></svg
          >
        </Button>
      </div>
    </div>
  </div>
</section>
