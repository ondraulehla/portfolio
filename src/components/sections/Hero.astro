---
import type { Locale } from '@/i18n/config';
import { localePath, useTranslations } from '@/i18n/utils';
import { site } from '@/data/site';
import Button from '@/components/ui/Button.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<section class="border-line/70 border-b">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <!-- masthead: monospace meta row, editorial rule -->
    <div
      class="hero-rise text-ink-faint flex flex-wrap items-center justify-between gap-x-6 gap-y-2 border-b border-dashed border-[var(--line)] py-4 font-mono text-xs tracking-wide uppercase"
    >
      <span>{site.name}</span>
      <span class="hidden sm:inline">{site.location[locale]}</span>
      <span class="text-accent inline-flex items-center gap-2">
        <span class="bg-accent inline-block size-2" aria-hidden="true"></span>
        {t('hero.available')}
      </span>
    </div>

    <div class="grid gap-x-10 pt-16 pb-16 sm:pt-24 sm:pb-24 lg:grid-cols-12">
      <div class="lg:col-span-9">
        <h1
          class="hero-rise font-display text-ink text-[length:var(--text-fluid-xl)] leading-[0.98] font-bold tracking-[-0.03em]"
          data-hero-title
        >
          {t('hero.title.line1')}<br />
          <span class="text-accent">{t('hero.title.line2')}</span>
        </h1>

        <p class="hero-rise-late text-ink-muted mt-8 max-w-2xl text-lg leading-relaxed text-balance sm:text-xl">
          {t('hero.subtitle')}
        </p>

        <div class="hero-rise-late mt-10 flex flex-wrap items-center gap-3">
          <Button href={`${localePath(locale, '/')}#projects`} variant="primary">
            {t('hero.cta.projects')}
            <svg
              class="size-4 transition-transform group-hover:translate-y-0.5"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M12 5v14m-7-7 7 7 7-7"></path></svg
            >
          </Button>
          <Button href={`/cv/ondrej-ulehla-${locale}.pdf`} variant="secondary" download>
            {t('hero.cta.cv')}
          </Button>
          <Button href={localePath(locale, '/playground')} variant="ghost" prefetch>
            {t('hero.cta.playground')}
            <svg
              class="size-4 transition-transform group-hover:translate-x-0.5"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M5 12h14m-7-7 7 7-7 7"></path></svg
            >
          </Button>
        </div>
      </div>

      <!-- right rail: monospace index, purely typographic character -->
      <aside
        class="hero-rise-late text-ink-faint mt-12 hidden self-end font-mono text-xs leading-relaxed lg:col-span-3 lg:mt-0 lg:block"
        aria-hidden="true"
      >
        <div class="border-line space-y-1 border-t pt-4">
          <div class="flex justify-between"><span>FULLSTACK</span><span class="text-ink-muted">01</span></div>
          <div class="flex justify-between"><span>AI ENGINEER</span><span class="text-ink-muted">02</span></div>
          <div class="flex justify-between"><span>CLIENT WORK</span><span class="text-ink-muted">03</span></div>
          <div class="text-ink-faint/70 pt-3">© {year}</div>
        </div>
      </aside>
    </div>
  </div>
</section>
