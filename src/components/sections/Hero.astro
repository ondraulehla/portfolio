---
import type { Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/utils';
import LineField from '@/components/ui/LineField.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const posterSize = 'text-[length:var(--text-fluid-poster)] leading-[0.92]';
---

<section class="border-line/70 relative overflow-hidden border-b">
  <!-- interactive line field: fine engraved verticals bending away from the cursor -->
  <div class="absolute inset-x-0 top-0 bottom-24 [mask-image:linear-gradient(to_bottom,black_58%,transparent_100%)]">
    <LineField />
  </div>

  <div class="relative mx-auto max-w-6xl px-5 sm:px-8">
    <div class="pt-14 pb-16 sm:pt-20 sm:pb-24">
      <h1 class:list={['hero-rise font-poster text-ink', posterSize]} data-hero-title>
        {t('hero.title.line1')}<br />
        <span class="text-accent">{t('hero.title.line2')}</span>
      </h1>

      <p class="hero-rise-late text-ink-muted mt-9 max-w-2xl text-lg leading-relaxed text-balance sm:text-xl">
        {t('hero.subtitle')}
      </p>

    </div>
  </div>
</section>
