---
import type { Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/utils';
import { cv, formatMonth } from '@/data/cv';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Badge from '@/components/ui/Badge.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="mx-auto max-w-6xl scroll-mt-20 px-5 py-16 sm:px-8 sm:py-24" id="experience">
  <SectionHeading kicker={t('experience.kicker')} heading={t('experience.heading')} />

  <ol class="relative space-y-12 border-l border-[var(--line)] pl-8" data-timeline>
    {
      cv.experience.map((job) => (
        <li class="relative" data-reveal>
          <span
            class="border-accent bg-surface absolute top-1.5 -left-[2.42rem] size-3 rounded-full border-2"
            aria-hidden="true"
          />
          <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
            <h3 class="font-display text-ink text-xl font-semibold">{job.role[locale]}</h3>
            <p class="text-ink-faint font-mono text-xs tracking-[0.08em] uppercase">
              {formatMonth(job.start, locale)} – {job.end ? formatMonth(job.end, locale) : t('experience.present')}
            </p>
          </div>
          <p class="text-ink-muted mt-1 text-sm font-medium">
            {job.url ? (
              <a
                href={job.url}
                target="_blank"
                rel="noopener"
                class="hover:text-accent underline decoration-[var(--line)] underline-offset-4 transition-colors"
              >
                {job.company}
              </a>
            ) : (
              job.company
            )}
          </p>
          <p class="text-ink-muted mt-3 max-w-3xl leading-relaxed">{job.summary[locale]}</p>
          {job.highlights.length > 0 && (
            <ul class="border-line mt-4 max-w-3xl space-y-2.5 border-t pt-4">
              {job.highlights.map((h) => (
                <li class="text-ink-muted relative pl-5 text-sm leading-relaxed before:absolute before:top-[0.65em] before:left-0 before:h-px before:w-2.5 before:bg-[var(--ink-faint)]">
                  {h[locale]}
                </li>
              ))}
            </ul>
          )}
          {job.tech.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-2">
              {job.tech.map((item) => (
                <Badge>{item}</Badge>
              ))}
            </div>
          )}
        </li>
      ))
    }
  </ol>
</section>
