---
import type { Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/utils';
import { cv, skillLabel } from '@/data/cv';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Badge from '@/components/ui/Badge.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="mx-auto max-w-6xl scroll-mt-20 px-5 py-16 sm:px-8 sm:py-24" id="skills">
  <SectionHeading heading={t('skills.heading')} />

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      cv.skills.map((group) => (
        <div class="border-line border p-6" data-reveal>
          <h3 class="font-display text-ink mb-4 text-base font-semibold">{group.category[locale]}</h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <Badge>{skillLabel(item, locale)}</Badge>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
