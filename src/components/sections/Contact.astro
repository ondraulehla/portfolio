---
import type { Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/utils';
import { site } from '@/data/site';
import LiquidText from '@/components/ui/LiquidText.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<!-- the closing section sits centred, unlike the left-anchored ones above -->
<section class="mx-auto max-w-6xl scroll-mt-20 px-5 py-16 text-center sm:px-8 sm:py-28" id="contact">
  <div data-reveal>
    <h2 id="contact-heading" class="font-poster text-[length:clamp(3rem,6vw,4.5rem)]">
      <span class="inline-block"><LiquidText text={t('contact.heading')} /></span>
    </h2>
    <p class="text-ink-muted mx-auto mt-6 max-w-xl text-lg">{t('contact.text')}</p>
  </div>

  <!-- technical band: hairline cells with the header's ink-flood hover -->
  <div class="border-line mx-auto mt-10 max-w-2xl border text-left" data-reveal>
    <div class="border-line flex items-stretch border-b">
      <a
        href={`mailto:${site.email}`}
        class="cell-flood text-ink min-w-0 flex-1 truncate px-5 py-5 font-mono text-sm font-semibold tracking-wide sm:text-lg"
      >
        {site.email}
      </a>
      <button
        type="button"
        data-copy-email={site.email}
        class="cell-flood border-line w-28 shrink-0 cursor-pointer border-l font-mono text-xs tracking-[0.15em] uppercase"
      >
        <span data-copy-label>{t('contact.copy.short')}</span>
        <span data-copied-label hidden>{t('contact.copied')}</span>
      </button>
    </div>
    <div class="grid grid-cols-3">
      <a
        href={site.github}
        target="_blank"
        rel="me noopener"
        class="cell-flood px-4 py-4 text-center font-mono text-xs tracking-[0.15em] uppercase"
      >
        GitHub
      </a>
      <a
        href={site.linkedin}
        target="_blank"
        rel="me noopener"
        class="cell-flood border-line border-l px-4 py-4 text-center font-mono text-xs tracking-[0.15em] uppercase"
      >
        LinkedIn
      </a>
      <a
        href={`/cv/ondrej-ulehla-${locale}.pdf`}
        download
        class="cell-flood border-line border-l px-4 py-4 text-center font-mono text-xs tracking-[0.15em] uppercase"
      >
        {t('contact.cv.short')}
      </a>
    </div>
  </div>
</section>

<script>
  function initCopy() {
    document.querySelectorAll<HTMLButtonElement>('[data-copy-email]').forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = 'true';
      const label = btn.querySelector<HTMLElement>('[data-copy-label]')!;
      const copied = btn.querySelector<HTMLElement>('[data-copied-label]')!;
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.copyEmail!);
          label.hidden = true;
          copied.hidden = false;
          setTimeout(() => {
            label.hidden = false;
            copied.hidden = true;
          }, 1800);
        } catch {}
      });
    });
  }
  initCopy();
  document.addEventListener('astro:page-load', initCopy);
</script>
